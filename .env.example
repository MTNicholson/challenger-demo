# PostgreSQL connection string.
# Локально можно поднять Postgres в Docker или указать базу на VDS.
DATABASE_URL="postgresql://challenger:challenger@localhost:5432/challenger_demo?schema=public"

# Минимум 32 символа. Для production сгенерируйте новый секрет:
# openssl rand -base64 32
JWT_SECRET="replace-with-at-least-32-random-characters"
