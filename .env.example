# Локальная dev-БД. Не используйте production-секреты в .env.local.
DATABASE_URL="postgresql://challenger:challenger@localhost:5432/challenger_demo_dev?schema=public"

# Минимум 32 символа. Для production сгенерируйте отдельный секрет.
JWT_SECRET="local-dev-secret-at-least-32-characters-long"

# Для локального http://localhost:3000 cookie не должны требовать HTTPS.
AUTH_COOKIE_SECURE="false"

# Dadata address suggestions for brand locations. Keep real keys only in local/production env files.
DADATA_API_TOKEN=""
DADATA_SECRET=""
DADATA_BASE_URL="https://suggestions.dadata.ru/suggestions/api/4_1/rs"
