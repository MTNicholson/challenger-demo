generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  phone        String?  @unique
  passwordHash String
  name         String
  city         String
  avatarUrl    String?
  coinsBalance Int      @default(1250)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
